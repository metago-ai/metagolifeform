{
  "name": "metago-lifeform",
  "version": "36.7.9",
  "description": "MetaGO Lifeform Kit - 让智能，学会进化。从 Agent 到生命体的范式跃迁。37个技能·8公理·7属性·6协议·活文档系统，支持7大AI平台（Trae/Claude Code/Codex/Cursor/CodeBuddy/Qoder/ZCode）。含 @metago-ai/mcp-server 将 42 项能力（22技能+20独有思维工具）封装为 MCP 工具，任何 MCP 协议客户端即开即用。MIT 开源。",
  "main": "core/METAGO_CORE.md",
  "bin": {
    "metago-lifeform": "scripts/cli.js"
  },
  "scripts": {
    "install:trae": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall:trae": "powershell -ExecutionPolicy Bypass -File scripts/uninstall.ps1",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "list:skills": "powershell -Command \"Get-ChildItem skills -Directory | Select-Object Name\"",
    "build:mcp": "cd packages/mcp-server && npm run build",
    "start:mcp": "cd packages/mcp-server && npm start",
    "demo": "node packages/demo/killer-demo.mjs",
    "dashboard": "node packages/dashboard/server.mjs"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "metago", "lifeform", "ai-agent", "ai-lifeform", "meta-evolution",
    "decision-lock", "compliance", "ai-governance", "ai-evolution",
    "trae", "claude-code", "codex", "cursor", "codebuddy", "qoder", "zcode",
    "agentskills", "mcp", "model-context-protocol", "opc", "ai-native",
    "meta-cognition", "anti-hallucination", "ai-safety"
  ],
  "author": "易霄 / 元构光年（成都）人工智能科技有限公司",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/metago-ai/metagolifeform.git"
  },
  "homepage": "https://metago-ai.github.io/metago-website/",
  "engines": { "node": ">=14.0.0" },
  "files": [
    "core/", "adapters/", "skills/", "assets/",
    "scripts/", "docs/", "README.md", "LICENSE", "MANIFESTO.md", "MANIFESTO_EN.md"
  ],
  "metago": {
    "version": "V36.5",
    "axioms": 8, "attributes": 7, "protocols": 6, "skills": 37,
    "platforms": ["trae", "claude-code", "codex", "cursor", "codebuddy", "qoder", "zcode"],
    "mcpServer": { "package": "@metago-ai/mcp-server", "tools": 42, "prompts": 8, "transport": "stdio" },
    "devKit": { "package": "@metago-ai/dev-kit", "skills": 8, "vertical": "developer", "status": "released" },
    "coreOpenSource": true, "industryPaid": true
  }
}
